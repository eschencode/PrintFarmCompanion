{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "3dtracker",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": ["nodejs_compat_v2"],
  "pages_build_output_dir": ".svelte-kit/cloudflare",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "printfarmcompanion-db",
