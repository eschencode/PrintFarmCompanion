# Pi Bridge — environment variables
# Copy to .env and fill in your values

# Cloudflare Workers will POST status updates here
WEBHOOK_URL=https://your-worker.workers.dev/api/pi/webhook

# Must match PI_WEBHOOK_SECRET in your CF Workers environment
WEBHOOK_SECRET=change-me-to-a-random-string

# Directory where uploaded .gcode.3mf files are stored on the Pi
FILES_DIR=/home/pi/printfarm/files

# Note: printer IP/serial/access code are sent per-request from CF Workers
# and stored per-printer in D1. No printer config needed here.
