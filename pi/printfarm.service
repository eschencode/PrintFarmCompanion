[Unit]
Description=PrintFarm Pi Bridge
After=network.target

[Service]
Type=simple
User=linus
WorkingDirectory=/home/linus/printfarm
EnvironmentFile=-/home/linus/printfarm/.env
ExecStart=/home/linus/printfarm/venv/bin/uvicorn pi.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
