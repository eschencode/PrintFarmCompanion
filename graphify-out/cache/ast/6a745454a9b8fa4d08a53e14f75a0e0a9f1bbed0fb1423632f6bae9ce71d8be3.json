 {"caller_nid": "ai_context_builder_aicontextbuilder_getinventorywithvelocity", "callee": "floor", "is_member_call": true, "source_file": "/Users/linus/Documents/dilemma/dillemaDev/PrintFarmCompanion/src/lib/ai/context-builder.ts", "source_location": "L56"}, {"caller_nid": "ai_context_builder_aicontextbuilder_getinventorywithvelocity", "callee": "now", "is_member_call": true, "source_file": "/Users/linus/Documents/dilemma/dillemaDev/PrintFarmCompanion/src/lib/ai/context-builder.ts", "source_location": "L56"}, {"caller_nid": "ai_context_builder_aicontextbuilder_getinventorywithvelocity", "callee": "get", "is_member_call": true, "source_file": "/Users/linus/Documents/dilemma/dillemaDev/PrintFarmCompanion/src/lib/ai/context-builder.ts", "source_location": "L63"}, {"caller_nid": "ai_context_builder_aicontextbuilder_getinventorywithvelocity", "callee": "fill", "is_member_call": true, "source_file": "/Users/linus/Documents/dilemma/dillemaDev/PrintFarmCompanion/src/lib/ai/context-builder.ts", "source_location": "L65"}, {"caller_nid": "ai_context_builder_aicontextbuilder_getinventorywithvelocity", "callee": "set", "is_member_call": true, "source_file": "/Users/linus/Documents/dilemma/dillemaDev/PrintFarmCompanion/src/lib/ai/context-builder.ts", "source_location": "L66"}, {"caller_nid": "ai_context_builder_aicontextbuilder_getinventorywithvelocity", "callee": "map", "is_member_call": true, "source_file": "/Users/linus/Documents/dilemma/dillemaDev/PrintFarmCompanion/src/lib/ai/context-builder.ts", "source_location": "L71"}, {"caller_nid": "ai_context_builder_aicontextbuilder_getmodulescontext", "callee": "await this.db.prepare(`\n      SELECT\n        pm.id,\n        pm.name,\n        pm.inventory_slug,\n        pm.expected_weight,\n        pm.expected_time,\n        pm.objects_per_print,\n        pm.default_spool_preset_id as preset_id,\n        sp.name as preset_name,\n        pm.printer_model,\n        pm.printer_model_id\n      FROM print_modules pm\n      LEFT JOIN spool_presets sp ON pm.default_spool_preset_id = sp.id\n      WHERE pm.active = 1\n    `).all", "is_member_call": false, "source_file": "/Users/linus/Documents/dilemma/dillemaDev/PrintFarmCompanion/src/lib/ai/context-builder.ts", "source_location": "L105"}, {"caller_nid": "ai_context_builder_aicontextbuilder_getmodulescontext", "callee": "prepare", "is_member_call": true, "source_file": "/Users/linus/Documents/dilemma/dillemaDev/PrintFarmCompanion/src/lib/ai/context-builder.ts", "source_location": "L105"}, {"caller_nid": "ai_context_builder_aicontextbuilder_getallprinterswithqueuedjobs", "callee": "await this.db.prepare(`\n    SELECT\n      p.*,\n      pj.module_id,\n      pm.name as module_name,\n      pj.status as job_status\n    FROM printers p\n    LEFT JOIN print_jobs pj ON pj.printer_id = p.id AND pj.status IN ('queued', 'printing')\n    LEFT JOIN print_modules pm ON pj.module_id = pm.id\n    ORDER BY p.id, pj.id\n  `).all", "is_member_call": false, "source_file": "/Users/linus/Documents/dilemma/dillemaDev/PrintFarmCompanion/src/lib/ai/context-builder.ts", "source_location": "L131"}, {"caller_nid": "ai_context_builder_aicontextbuilder_getallprinterswithqueuedjobs", "callee": "prepare", "is_member_call": true, "source_file": "/Users/linus/Documents/dilemma/dillemaDev/PrintFarmCompanion/src/lib/ai/context-builder.ts", "source_location": "L131"}, {"caller_nid": "ai_context_builder_aicontextbuilder_getallprinterswithqueuedjobs", "callee": "has", "is_member_call": true, "source_file": "/Users/linus/Documents/dilemma/dillemaDev/PrintFarmCompanion/src/lib/ai/context-builder.ts", "source_location": "L146"}, {"caller_nid": "ai_context_builder_aicontextbuilder_getallprinterswithqueuedjobs", "callee": "set", "is_member_call": true, "source_file": "/Users/linus/Documents/dilemma/dillemaDev/PrintFarmCompanion/src/lib/ai/context-builder.ts", "source_location": "L147"}, {"caller_nid": "ai_context_builder_aicontextbuilder_getallprinterswithqueuedjobs", "callee": "push", "is_member